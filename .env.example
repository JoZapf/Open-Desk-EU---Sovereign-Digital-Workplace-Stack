# =============================================================================
# Open-Desk EU — Deployment Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your deployment.
# Used by: all compose files (variable interpolation) and scripts/verify-network-routing.sh
# This file is git-ignored — the .env with your actual values stays local.
# =============================================================================

# --- Domains ---
DOMAIN_CLOUD=cloud.example.com
DOMAIN_IAM=id.example.com
DOMAIN_OFFICE=office.example.com

# --- Host ---
HOST_IP=192.168.1.100
LAN_SUBNET=192.168.1.0/24

# --- Traefik ---
TRAEFIK_PORT=8443
TRAEFIK_DASHBOARD_PORT=8890
TRAEFIK_FRONTEND_IP=172.31.1.3

# --- Docker Networks (subnets) ---
NET_FRONTEND=172.31.1.0/24
NET_BACKEND=172.31.2.0/24
NET_DB=172.31.3.0/24
NET_MAIL=172.31.4.0/24
NET_WOPI=172.31.5.0/24

# --- Container Names ---
CT_TRAEFIK=opendesk_traefik
CT_KEYCLOAK=opendesk_keycloak
CT_KEYCLOAK_DB=opendesk_keycloak_db
CT_NEXTCLOUD=opendesk_nextcloud
CT_NEXTCLOUD_DB=opendesk_nextcloud_db
CT_NEXTCLOUD_REDIS=opendesk_nextcloud_redis
CT_NEXTCLOUD_CRON=opendesk_nextcloud_cron
CT_COLLABORA=opendesk_collabora

# --- Data Directory (persistent volumes base path) ---
DATA_DIR=/srv/opendesk-data

# --- Report Output (absolute path recommended) ---
REPORT_DIR=/path/to/opendesk/docs
